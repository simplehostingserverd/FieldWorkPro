# FieldPro Backend Environment Variables - Example

# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fieldpro_dev
DB_USER=postgres
DB_PASSWORD=your_database_password

# API Configuration
API_BASE_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8081

# Security
BCRYPT_ROUNDS=12

# Development
DEBUG=true

# Integration Settings

# QuickBooks Online Integration
QUICKBOOKS_ENABLED=false
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REDIRECT_URI=http://localhost:8080/api/integrations/quickbooks/callback
QUICKBOOKS_SANDBOX=true
QUICKBOOKS_COMPANY_ID=your_company_id
QUICKBOOKS_WEBHOOK_SECRET=your_webhook_secret

# Stripe Payment Processing
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_TEST_MODE=true

# Carrier Equipment Manufacturer
CARRIER_ENABLED=false
CARRIER_DEALER_CODE=your_dealer_code
CARRIER_API_KEY=your_carrier_api_key
CARRIER_ENVIRONMENT=sandbox

# Ferguson Parts Distributor
FERGUSON_ENABLED=false
FERGUSON_ACCOUNT_NUMBER=your_account_number
FERGUSON_API_KEY=your_ferguson_api_key
FERGUSON_BRANCH_CODE=your_branch_code
FERGUSON_ENVIRONMENT=sandbox

# HubSpot CRM and Marketing
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token
HUBSPOT_PORTAL_ID=your_portal_id
HUBSPOT_APP_ID=your_app_id

# Trane Equipment Manufacturer
TRANE_ENABLED=false
TRANE_DEALER_CODE=your_trane_dealer_code
TRANE_API_KEY=your_trane_api_key
TRANE_ENVIRONMENT=sandbox

# Johnstone Supply Parts Distributor
JOHNSTONE_ENABLED=false
JOHNSTONE_ACCOUNT_NUMBER=your_johnstone_account
JOHNSTONE_API_KEY=your_johnstone_api_key
JOHNSTONE_BRANCH_CODE=your_branch_code
JOHNSTONE_ENVIRONMENT=sandbox

# Square Payment Processing
SQUARE_ENABLED=false
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your_location_id

# Salesforce CRM
SALESFORCE_ENABLED=false
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_PASSWORD=your_salesforce_password
SALESFORCE_SECURITY_TOKEN=your_security_token
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_ENVIRONMENT=production
