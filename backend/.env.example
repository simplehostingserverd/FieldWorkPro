# FieldPro Backend Environment Variables - Example

# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fieldpro_dev
DB_USER=postgres
DB_PASSWORD=your_database_password

# API Configuration
API_BASE_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8081

# Security
BCRYPT_ROUNDS=12

# Development
DEBUG=true
