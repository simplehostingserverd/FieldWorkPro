{
  "name": "fieldpro",
  "version": "1.0.0",
  "description": "Field Service Management Application",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"blue,green\" \"npm run dev --prefix backend\" \"npm run start --prefix web-dashboard\"",
    "start": "npm run dev",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run start --prefix web-dashboard",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix web-dashboard",
    "build": "npm run build --prefix backend && npm run build --prefix web-dashboard",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:setup": "cd backend && node setup-db.js",
    "cache:flush": "cd backend && node -e \"require('./services/cache').connect().then(() => require('./services/cache').flush()).then(() => process.exit(0))\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "field-service",
    "management",
    "crm",
    "scheduling"
  ],
  "author": "FieldPro Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "dependencies": {
    "react-beautiful-dnd": "^13.1.1"
  }
}
